## 🔹 5. Implementation (Python)

```python id="viz123"
import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns

# Load dataset
df = pd.read_excel("road_accidents_dataset.xlsx")

# Convert time column
df['Start_Time'] = pd.to_datetime(df['Start_Time'])

# Extract hour
df['Hour'] = df['Start_Time'].dt.hour

# Line chart: accidents by hour
df['Hour'].value_counts().sort_index().plot(kind='line')
plt.title("Accidents by Hour")
plt.xlabel("Hour")
plt.ylabel("Number of Accidents")
plt.show()

# Bar chart: severity distribution
sns.countplot(x='Severity', data=df)
plt.title("Severity Distribution")
plt.show()

# Pie chart: weather condition
df['Weather_Condition'].value_counts().plot(kind='pie', autopct='%1.1f%%')
plt.title("Weather Conditions")
plt.show()
```

